# ====================================
# DevMetrics Environment Variables
# ====================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Database
DATABASE_URL=

# Redis
REDIS_URL=

# RabbitMQ
RABBITMQ_URL=

# GitHub OAuth (get yours at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# App
NODE_ENV=
API_PORT=
WEB_PORT=

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=