# ====================================
# DevMetrics Environment Variables
# ====================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Database
DATABASE_URL=postgresql://devmetrics:devmetrics_secret@localhost:5432/devmetrics

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://devmetrics:devmetrics_secret@localhost:5672/devmetrics

# GitHub OAuth (get yours at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback

# App
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=