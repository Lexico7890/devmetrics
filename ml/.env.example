# Database (Apunta a AWS RDS en Producción)
# Ejemplo AWS: postgresql://admin:StrongPassword@devmetrics-db.xxxx.us-east-1.rds.amazonaws.com:5432/devmetrics
DATABASE_URL=postgresql://postgres:password@localhost:5432/devmetrics
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=devmetrics

# Redis (Apunta a AWS ElastiCache en Producción)
# Ejemplo AWS: redis://devmetrics-cache.xxxx.us-east-1.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=technical_debt_prediction

# Model
MODEL_PATH=./models
FEATURE_STORE_TTL=86400  # 24 horas en segundos